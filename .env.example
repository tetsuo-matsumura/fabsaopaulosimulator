# Chaves GRÁTIS da Groq — pegue em https://console.groq.com/keys
# Você pode configurar de 1 a 6 chaves. O app sorteia uma por requisição
# (rotação aleatória) e, se uma estiver no limite, cai pra próxima.
GROQ_API_KEY=gsk_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
GROQ_API_KEY_1=gsk_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
GROQ_API_KEY_2=gsk_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
GROQ_API_KEY_3=gsk_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
GROQ_API_KEY_4=gsk_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
GROQ_API_KEY_5=gsk_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# (opcional) troca o modelo. Padrão: llama-3.3-70b-versatile
# GROQ_MODEL=llama-3.3-70b-versatile
